<%= turbo_frame_tag "budget_settings_dialog", class: "flex flex-col" do %>
  <header class="flex items-center justify-between border-b border-taupe-200 px-5 py-4">
    <h2 id="budget_settings_dialog_title" class="text-lg font-semibold text-taupe-800">
      <%= t(".title") %>
    </h2>

    <button
      type="button"
      data-action="dialog#close"
      aria-label="<%= t(".close") %>"
      class="
        flex h-8 w-8 items-center justify-center rounded-lg text-taupe-500 cursor-pointer
        hover:bg-taupe-100 hover:text-taupe-800 focus-visible:outline-none focus-visible:ring-2
        focus-visible:ring-indigo-500
      "
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        class="h-5 w-5"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M4.28 4.28a.75.75 0 0 0-1.06 1.06L6.94 8l-3.72 3.72a.75.75 0 1 0 1.06 1.06L8 9.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L9.06 8l3.72-3.72a.75.75 0 0 0-1.06-1.06L8 6.94 4.28 3.22Z"
        />
      </svg>
    </button>
  </header>

  <div class="px-5 py-5">
    <%= form_with model:  @budget,
                  url:    budget_path(@budget),
                  method: :patch,
                  id:     "budget_form",
                  class:  "highlight-errors" do |f| %>
      <%= f.label :name, t(".name"), class: "mb-1 block text-sm font-medium text-taupe-700" %>

      <div class="field-card rounded-lg border border-taupe-300">
        <div
          class="
            flex items-center px-3 py-2 rounded-lg focus-within:outline-none focus-within:ring-2
            focus-within:ring-indigo-500 focus-within:ring-inset
          "
        >
          <%= f.text_field :name,
                           autocapitalize: "words",
                           autocomplete:   "off",
                           autocorrect:    "off",
                           autofocus:      true,
                           class:          "w-full bg-transparent border-none outline-none text-base text-taupe-800 focus:ring-0",
                           maxlength:      Budget::MAXIMUM_NAME_LENGTH,
                           required:       true %>
        </div>
      </div>

      <% if @budget.errors[:name].present? %>
        <p role="alert" class="mt-2 text-xs text-red-700">
          <%= Budget.human_attribute_name(:name) %> <%= @budget.errors[:name].first %>.
        </p>
      <% end %>
    <% end %>

    <div class="mt-6 flex items-center justify-end gap-2">
      <button
        type="button"
        data-action="dialog#close"
        class="
          px-3 py-1.5 text-sm font-medium text-taupe-600 rounded-lg cursor-pointer
          hover:bg-taupe-100 focus-visible:outline-none focus-visible:ring-2
          focus-visible:ring-indigo-500 focus-visible:ring-offset-2
        "
      >
        <%= t(".cancel") %>
      </button>

      <%= submit_tag t(".submit"),
                     form:  "budget_form",
                     class: "
                       px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 rounded-lg cursor-pointer
                       hover:bg-indigo-700 focus-visible:outline-none focus-visible:ring-2
                       focus-visible:ring-indigo-500 focus-visible:ring-offset-2
                     " %>
    </div>
  </div>
<% end %>
