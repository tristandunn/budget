<div class="flex flex-col min-h-dvh">
  <div data-controller="dialog" data-action="dialog:close->dialog#close">
    <dialog
      id="category_dialog_modal"
      class="dialog"
      aria-labelledby="category_dialog_title"
      data-dialog-target="dialog"
      data-action="click->dialog#backdropClose cancel->dialog#cancel"
    >
      <turbo-frame id="category_dialog" data-action="turbo:frame-load->dialog#open"></turbo-frame>
    </dialog>
  </div>

  <div data-controller="dialog" data-action="dialog:close->dialog#close">
    <dialog
      id="category_rename_dialog_modal"
      class="dialog"
      aria-labelledby="category_rename_dialog_title"
      data-dialog-target="dialog"
      data-action="click->dialog#backdropClose cancel->dialog#cancel"
    >
      <turbo-frame id="category_rename_dialog" data-action="turbo:frame-load->dialog#open"></turbo-frame>
    </dialog>
  </div>

  <div data-controller="dialog" data-action="dialog:close->dialog#close">
    <dialog
      id="category_target_dialog_modal"
      class="dialog"
      aria-labelledby="category_target_dialog_title"
      data-dialog-target="dialog"
      data-action="click->dialog#backdropClose cancel->dialog#cancel"
    >
      <turbo-frame id="category_target_dialog" data-action="turbo:frame-load->dialog#open"></turbo-frame>
    </dialog>
  </div>

  <div data-controller="dialog" data-action="dialog:close->dialog#close">
    <dialog
      id="payees_dialog_modal"
      class="dialog"
      aria-labelledby="payees_dialog_title"
      data-dialog-target="dialog"
      data-action="click->dialog#backdropClose cancel->dialog#cancel"
    >
      <turbo-frame id="payees_dialog" data-action="turbo:frame-load->dialog#open"></turbo-frame>
    </dialog>
  </div>

  <div data-controller="dialog" data-action="dialog:close->dialog#close">
    <dialog
      id="payee_rename_dialog_modal"
      class="dialog"
      aria-labelledby="payee_rename_dialog_title"
      data-dialog-target="dialog"
      data-action="click->dialog#backdropClose cancel->dialog#cancel"
    >
      <turbo-frame id="payee_rename_dialog" data-action="turbo:frame-load->dialog#open"></turbo-frame>
    </dialog>
  </div>

  <header
    class="
      sticky top-0 z-10 grid grid-cols-3 items-center whitespace-nowrap border-b
      border-taupe-200 bg-white px-4 pt-safe pb-4
    "
  >
    <div class="leading-tight justify-self-start">
      <%= render "available_to_assign", budget: @budget %>
    </div>

    <div class="flex items-center gap-2 justify-self-center">
      <%= link_to(
            month_budget_path(@budget, year: @budget_snapshot.previous_date.year, month: @budget_snapshot.previous_date.month),
            aria:  { label: t(".previous_month"), disabled: @budget_snapshot.first_month? || nil },
            class: navigation_arrow_class(@budget_snapshot.first_month?),
            id:    "previous-month"
          ) do %>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
            clip-rule="evenodd"
          />
        </svg>
      <% end %>

      <h1 class="text-lg font-semibold">
        <% if @budget_snapshot.current_month? %>
          <%= l(@budget_snapshot.date, format: :month_and_year) %>
        <% else %>
          <%= link_to l(@budget_snapshot.date, format: :month_and_year),
                      budget_path(@budget),
                      class: "text-inherit no-underline" %>
        <% end %>
      </h1>

      <%= link_to(
            month_budget_path(@budget, year: @budget_snapshot.next_date.year, month: @budget_snapshot.next_date.month),
            aria:  { label: t(".next_month"), disabled: @budget_snapshot.last_month? || nil },
            class: navigation_arrow_class(@budget_snapshot.last_month?),
            id:    "next-month"
          ) do %>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
            clip-rule="evenodd"
          />
        </svg>
      <% end %>
    </div>

    <div data-controller="popover" class="relative justify-self-end">
      <button
        type="button"
        data-action="popover#toggle"
        aria-label="<%= t(".menu") %>"
        class="
          m-0.5 flex h-6 w-6 items-center justify-center rounded-full border-2 border-taupe-800
          leading-none text-taupe-800 focus-visible:outline-none focus-visible:ring-2
          focus-visible:ring-indigo-500 focus-visible:ring-offset-2
        "
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          class="h-[18px] w-[18px] translate-y-px"
          fill="currentColor"
        >
          <path
            d="M8 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM3.5 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm9 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
          />
        </svg>
      </button>

      <div
        data-popover-target="menu"
        class="
          absolute right-0 top-full z-10 mt-1 hidden overflow-hidden rounded-lg border
          border-taupe-200 bg-white shadow-lg whitespace-nowrap divide-y divide-taupe-200
        "
      >
        <%= link_to budget_payees_path(@budget),
                    data:  { turbo_frame: "payees_dialog" },
                    class: "flex w-full items-center justify-between gap-4 px-3 py-2 text-left text-sm text-taupe-800 no-underline" do %>
          <%= t(".manage_payees") %>

          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            class="h-4 w-4 text-taupe-800"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10.561 8.073a6.005 6.005 0 0 1 3.432 5.142.75.75 0 1 1-1.498.07 4.5 4.5 0 0 0-8.99 0 .75.75 0 0 1-1.498-.07 6.004 6.004 0 0 1 3.431-5.142 3.999 3.999 0 1 1 5.123 0ZM10.5 5a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"
            />
          </svg>
        <% end %>

        <%= button_to session_path,
                      method: :delete,
                      class:  "
                        flex w-full items-center justify-between gap-4 px-3 py-2 text-left text-sm
                        text-taupe-800
                      " do %>
          <%= t(".sign_out") %>

          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            class="h-4 w-4 text-taupe-800"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M2 2.75C2 1.784 2.784 1 3.75 1h2.5a.75.75 0 0 1 0 1.5h-2.5a.25.25 0 0 0-.25.25v10.5c0 .138.112.25.25.25h2.5a.75.75 0 0 1 0 1.5h-2.5A1.75 1.75 0 0 1 2 13.25Z"
            />

            <path
              d="M10.273 5.18a.75.75 0 0 1 1.06 0l2.5 2.5a.75.75 0 0 1 0 1.06l-2.5 2.5a.749.749 0 0 1-1.275-.326.749.749 0 0 1 .215-.734L11.44 8.75H6.75a.75.75 0 0 1 0-1.5h4.69L10.273 6.24a.75.75 0 0 1 0-1.06Z"
            />
          </svg>
        <% end %>
      </div>
    </div>
  </header>

  <section class="flex-1 -mt-px">
    <table class="w-full text-left">
      <% @budget.categories.reject(&:inflow?).sort_by(&:position).each do |category| %>
        <%= render "categories/category_header",
                   category:        category,
                   budget_snapshot: @budget_snapshot %>

        <tbody
          class="[.group.collapsed+&]:hidden"
          data-collapsible-content="collapsible-category-<%= category.id %>"
        >
          <% category.subcategories.sort_by(&:position).each do |subcategory| %>
            <%= render "categories/subcategory_row",
                       budget:          @budget,
                       subcategory:     subcategory,
                       budget_snapshot: @budget_snapshot %>
          <% end %>
        </tbody>
      <% end %>
    </table>
  </section>

  <%= render "shared/toolbar", budget: @budget %>
</div>
