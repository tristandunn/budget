<div class="flex flex-col min-h-screen">
  <header class="overflow-hidden text-center bg-white">
    <h1 class="p-4 text-lg font-semibold"><%= @date.strftime("%B %Y") %></h1>
  </header>

  <section class="flex-1">
    <table class="w-full text-left">
      <% @budget.categories.sort_by(&:position).each do |category| %>
        <thead class="bg-slate-100 border-y border-slate-200">
          <tr>
            <th scope="col" class="py-2 px-4 text-lg truncate" style="max-width:1px;">
              <div
                class="
                  inline-block relative -inset-y-1 mr-2 w-3 h-3 border-r-2 border-b-2 transform
                  rotate-45 border-slate-500
                "
              ></div>

              <%= category.name %>
            </th>

            <% @snapshots[category.id].tap do |snapshot| %>
              <th scope="col" class="py-2 px-4 w-1/4 text-right">
                <div class="text-sm font-normal">Assigned</div>
                <div><%= number_to_currency Money.from_cents(snapshot.amount_assigned) %></div>
              </th>

              <th scope="col" class="py-2 px-4 w-1/4 text-right">
                <div class="text-sm font-normal">Available</div>
                <div><%= number_to_currency Money.from_cents(snapshot.amount_remaining) %></div>
              </th>
            <% end %>
          </tr>
        </thead>

        <tbody>
          <% category.subcategories.sort_by(&:position).each do |subcategory| %>
            <tr class="bg-white border-b border-slate-200">
              <th scope="row" class="py-3 px-4 font-normal whitespace-nowrap">
                <%= subcategory.name %>
              </th>

              <% @snapshots[subcategory.id].tap do |snapshot| %>
                <td class="py-3 px-4 font-semibold text-right">
                  <%= number_to_currency Money.from_cents(snapshot.amount_assigned) %>
                </td>

                <td class="py-3 px-4 font-semibold text-right">
                  <div class="inline-block py-0.5 px-2 -my-0.5 -mx-2 rounded-full <%= amount_color(snapshot.amount_remaining) %>">
                    <%= number_to_currency Money.from_cents(snapshot.amount_remaining) %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      <% end %>
    </table>
  </section>

  <footer
    class="
      sticky bottom-0 pt-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] bg-slate-50 border-t
      border-slate-200
    "
  >
    <nav class="flex items-center py-2">
      <div class="flex-1 flex justify-evenly">
        <%= link_to "#", class: "flex flex-col items-center text-slate-800" do %>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M6.75 0a.75.75 0 0 1 .75.75V3h9V.75a.75.75 0 0 1 1.5 0V3h2.75c.966 0 1.75.784 1.75 1.75v16a1.75 1.75 0 0 1-1.75 1.75H3.25a1.75 1.75 0 0 1-1.75-1.75v-16C1.5 3.784 2.284 3 3.25 3H6V.75A.75.75 0 0 1 6.75 0ZM21 9.5H3v11.25c0 .138.112.25.25.25h17.5a.25.25 0 0 0 .25-.25Zm-17.75-5a.25.25 0 0 0-.25.25V8h18V4.75a.25.25 0 0 0-.25-.25Z"
            />
          </svg>

          <span class="text-[10px] font-semibold mt-0.5">Plan</span>
        <% end %>

        <%= link_to "#", class: "flex flex-col items-center text-slate-400 hover:text-slate-600" do %>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M15.25 14a.75.75 0 0 0 0 1.5h3.5a.75.75 0 0 0 0-1.5h-3.5Z" />

            <path
              d="M1.75 3h20.5c.966 0 1.75.784 1.75 1.75v14.5A1.75 1.75 0 0 1 22.25 21H1.75A1.75 1.75 0 0 1 0 19.25V4.75C0 3.784.784 3 1.75 3Zm-.25 7v9.25c0 .138.112.25.25.25h20.5a.25.25 0 0 0 .25-.25V10Zm0-5.25V8.5h21V4.75a.25.25 0 0 0-.25-.25H1.75a.25.25 0 0 0-.25.25Z"
            />
          </svg>

          <span class="text-[10px] font-semibold mt-0.5">Spending</span>
        <% end %>
      </div>

      <%= link_to new_budget_transaction_path(@budget),
                  id:    "add-transaction",
                  aria:  { label: t("transactions.new.submit") },
                  class: "flex flex-col items-center justify-center px-4 -mt-1" do %>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-10 h-10 bg-blue-100 hover:bg-blue-200 rounded-full text-blue-600"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12.75 7.75a.75.75 0 0 0-1.5 0v3.5h-3.5a.75.75 0 0 0 0 1.5h3.5v3.5a.75.75 0 0 0 1.5 0v-3.5h3.5a.75.75 0 0 0 0-1.5h-3.5v-3.5Z"
          />

          <path
            d="M12 1c6.075 0 11 4.925 11 11s-4.925 11-11 11S1 18.075 1 12 5.925 1 12 1ZM2.5 12a9.5 9.5 0 0 0 9.5 9.5 9.5 9.5 0 0 0 9.5-9.5A9.5 9.5 0 0 0 12 2.5 9.5 9.5 0 0 0 2.5 12Z"
          />
        </svg>
      <% end %>

      <div class="flex-1 flex justify-evenly">
        <%= link_to "#", class: "flex flex-col items-center text-slate-400 hover:text-slate-600" do %>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M7.5 1.75C7.5.784 8.284 0 9.25 0h5.5c.966 0 1.75.784 1.75 1.75V4h4.75c.966 0 1.75.784 1.75 1.75v14.5A1.75 1.75 0 0 1 21.25 22H2.75A1.75 1.75 0 0 1 1 20.25V5.75C1 4.784 1.784 4 2.75 4H7.5Zm-5 10.24v8.26c0 .138.112.25.25.25h18.5a.25.25 0 0 0 .25-.25v-8.26A4.235 4.235 0 0 1 18.75 13H5.25a4.235 4.235 0 0 1-2.75-1.01Zm19-3.24v-3a.25.25 0 0 0-.25-.25H2.75a.25.25 0 0 0-.25.25v3a2.75 2.75 0 0 0 2.75 2.75h13.5a2.75 2.75 0 0 0 2.75-2.75Zm-6.5-7a.25.25 0 0 0-.25-.25h-5.5a.25.25 0 0 0-.25.25V4h6Z"
            />
          </svg>

          <span class="text-[10px] font-semibold mt-0.5">Accounts</span>
        <% end %>

        <%= link_to "#", class: "flex flex-col items-center text-slate-400 hover:text-slate-600" do %>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M22.875 22.125H1.125q-.311 0-.53-.22-.22-.219-.22-.53 0-.311.22-.53.219-.22.53-.22h21.75q.311 0 .53.22.22.219.22.53 0 .311-.22.53-.219.22-.53.22Z"
            />

            <path
              d="M3.25 10.5h4a.25.25 0 0 1 .25.25v10a.25.25 0 0 1-.25.25h-4a.25.25 0 0 1-.25-.25v-10a.25.25 0 0 1 .25-.25Zm6-6h4a.25.25 0 0 1 .25.25v16a.25.25 0 0 1-.25.25h-4a.25.25 0 0 1-.25-.25v-16a.25.25 0 0 1 .25-.25Zm6 9h4a.25.25 0 0 1 .25.25v7a.25.25 0 0 1-.25.25h-4a.25.25 0 0 1-.25-.25v-7a.25.25 0 0 1 .25-.25Z"
            />
          </svg>

          <span class="text-[10px] font-semibold mt-0.5">Reflect</span>
        <% end %>
      </div>
    </nav>
  </footer>
</div>
