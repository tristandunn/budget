<header class="overflow-hidden bg-white">
  <h1 class="inline-block float-left p-4 text-lg font-semibold w-45">
    <%= @date.strftime("%B %Y") %>
  </h1>
</header>

<section>
  <table class="w-full text-left">
    <% @budget.categories.sort_by(&:position).each do |category| %>
      <thead class="bg-slate-100 border-y border-slate-200">
        <tr>
          <th scope="col" class="py-2 px-4 text-lg truncate" style="max-width:1px;">
            <div
              class="
                inline-block relative -inset-y-1 mr-2 w-3 h-3 border-r-2 border-b-2 transform
                rotate-45 border-slate-500
              "
            ></div>

            <%= category.name %>
          </th>

          <% @snapshots[category.id].tap do |snapshot| %>
            <th scope="col" class="py-2 px-4 w-1/4 text-right">
              <div class="text-sm font-normal">Assigned</div>
              <div><%= number_to_currency snapshot.amount_assigned %></div>
            </th>

            <th scope="col" class="py-2 px-4 w-1/4 text-right">
              <div class="text-sm font-normal">Available</div>
              <div><%= number_to_currency snapshot.amount_remaining %></div>
            </th>
          <% end %>
        </tr>
      </thead>

      <tbody>
        <% category.subcategories.sort_by(&:position).each do |subcategory| %>
          <tr class="bg-white border-b border-slate-200">
            <th scope="row" class="py-3 px-4 font-normal whitespace-nowrap">
              <%= subcategory.name %>
            </th>

            <% @snapshots[subcategory.id].tap do |snapshot| %>
              <td class="py-3 px-4 font-semibold text-right">
                <%= number_to_currency snapshot.amount_assigned %>
              </td>

              <td class="py-3 px-4 font-semibold text-right">
                <div class="inline-block py-0.5 px-2 -my-0.5 -mx-2 rounded-full <%= snapshot_color(snapshot) %>">
                  <%= number_to_currency snapshot.amount_remaining %>
                </div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    <% end %>
  </table>
</section>
