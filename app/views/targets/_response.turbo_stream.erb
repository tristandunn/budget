<%# locals: (budget:, category:, budget_snapshot:, previous_budget_snapshot:) %>
<%= turbo_stream.update "category_dialog" do %>
  <%= render "categories/details",
             budget:                   budget,
             category:                 category,
             budget_snapshot:          budget_snapshot,
             previous_budget_snapshot: previous_budget_snapshot %>
<% end %>

<%= turbo_stream.replace dom_id(category, :available) do %>
  <%= render "categories/available",
             category:        category,
             budget_snapshot: budget_snapshot %>
<% end %>

<%= turbo_stream.update "category_target_dialog" do %>
  <div data-controller="dialog-dismisser"></div>
<% end %>
