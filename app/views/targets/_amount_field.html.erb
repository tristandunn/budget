<%# locals: (form:, placeholder:) %>
<svg
  xmlns="http://www.w3.org/2000/svg"
  class="w-4 h-4 shrink-0 text-indigo-600"
  viewBox="0 0 20 20"
  fill="currentColor"
>
  <path
    fill-rule="evenodd"
    d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM10.75 5.75a.75.75 0 0 0-1.5 0v.5h-.5c-1.379 0-2.5 1.121-2.5 2.5s1.121 2.5 2.5 2.5h2c.554 0 1 .446 1 1s-.446 1-1 1h-3.5a.75.75 0 0 0 0 1.5h2v.5a.75.75 0 0 0 1.5 0v-.5h.5c1.379 0 2.5-1.121 2.5-2.5s-1.121-2.5-2.5-2.5h-2c-.554 0-1-.446-1-1s.446-1 1-1h3.5a.75.75 0 0 0 0-1.5h-2v-.5Z"
    clip-rule="evenodd"
  />
</svg>

<%= form.label :target_amount_input, class: "sr-only" %>

<%= form.text_field :target_amount_input,
                    autocomplete: "off",
                    autofocus:    true,
                    class:        "flex-1 bg-transparent border-none outline-none placeholder:text-taupe-400 focus:ring-0",
                    data:         {
                      action:                  "input->amount#input keydown->amount#keydown paste->amount#paste",
                      "amount-positive-value": "true",
                      controller:              "amount"
                    },
                    inputmode:    "decimal",
                    placeholder:  placeholder,
                    required:     true %>
