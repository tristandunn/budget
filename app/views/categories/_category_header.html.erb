<%# locals: (category:, budget_snapshot:) %>
<thead
  id="<%= dom_id(category, :header) %>"
  class="group bg-taupe-100 border-y border-taupe-200"
  data-controller="collapsible"
  data-collapsible-id-value="category-<%= category.id %>"
>
  <tr data-action="click->collapsible#toggle">
    <th scope="col" class="py-2 px-4 text-lg truncate max-w-px">
      <div
        class="
          inline-block relative -inset-y-1 mr-2 w-3 h-3 border-r-2 border-b-2 rotate-45
          border-taupe-500 group-[.collapsed]:inset-y-0
          group-[.collapsed]:translate-x-(--collapsible-arrow-shift)
          group-[.collapsed]:-rotate-45
        "
        data-collapsible-arrow
      ></div>

      <%= category.name %>
    </th>

    <th scope="col" class="py-2 px-4 w-1/4 text-right whitespace-nowrap">
      <div class="text-sm font-normal"><%= t(".assigned") %></div>
      <div><%= number_to_money budget_snapshot.snapshot_for(category.id).amount_assigned %></div>
    </th>

    <th scope="col" class="py-2 px-4 w-1/4 text-right whitespace-nowrap">
      <div class="text-sm font-normal"><%= t(".available") %></div>
      <div><%= number_to_money budget_snapshot.available_for(category) %></div>
    </th>
  </tr>
</thead>
