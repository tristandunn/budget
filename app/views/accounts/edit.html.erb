<%= turbo_frame_tag "account_dialog", class: "flex flex-col h-full" do %>
  <header class="relative p-4">
    <h2 id="account_dialog_title" class="text-lg font-semibold text-center"><%= t(".title") %></h2>

    <button type="button" class="absolute top-4 left-4 text-sm" data-action="dialog#close">
      <%= t(".cancel") %>
    </button>

    <button
      type="submit"
      form="account_form"
      class="absolute top-4 right-4 text-sm font-semibold text-indigo-600"
    >
      <%= t(".submit") %>
    </button>
  </header>

  <%= render "form",
             budget: @budget,
             form:   @form,
             method: :patch,
             url:    budget_account_path(@budget, @form.account) %>
<% end %>
