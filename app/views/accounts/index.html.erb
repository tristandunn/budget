<div class="flex flex-col min-h-screen">
  <header class="overflow-hidden text-center bg-white">
    <h1 class="p-4 text-lg font-semibold"><%= t(".title") %></h1>
  </header>

  <section class="flex-1">
    <div data-controller="collapsible" data-collapsible-id-value="cash">
      <div
        class="
          flex cursor-pointer items-center justify-between py-2 px-4 bg-taupe-100 border-y
          border-taupe-200
        "
        data-action="click->collapsible#toggle"
      >
        <h2 class="text-lg font-bold">
          <div
            class="
              inline-block relative -inset-y-1 mr-2 w-3 h-3 border-r-2 border-b-2
              border-taupe-500 rotate-45
            "
            data-collapsible-target="arrow"
          ></div>

          <%= t(".cash") %>
        </h2>

        <div class="text-right">
          <div class="text-sm font-normal"><%= t(".available") %></div>

          <div class="font-bold">
            <%= number_to_money @cash_accounts.sum(&:balance) %>
          </div>
        </div>
      </div>

      <ul class="divide-y divide-taupe-200" data-collapsible-content="collapsible-cash">
        <% @cash_accounts.each do |account| %>
          <li>
            <%= link_to budget_account_transactions_path(@budget, account),
                        class: "flex items-center justify-between py-3 px-4 bg-white" do %>
              <span class="font-medium"><%= account.name %></span>

              <span class="inline-block py-0.5 px-2 font-semibold rounded-full <%= amount_color(account.balance) %>">
                <%= number_to_money account.balance %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <div data-controller="collapsible" data-collapsible-id-value="credit">
      <div
        class="
          flex cursor-pointer items-center justify-between py-2 px-4 bg-taupe-100 border-y
          border-taupe-200
        "
        data-action="click->collapsible#toggle"
      >
        <h2 class="text-lg font-bold">
          <div
            class="
              inline-block relative -inset-y-1 mr-2 w-3 h-3 border-r-2 border-b-2
              border-taupe-500 rotate-45
            "
            data-collapsible-target="arrow"
          ></div>

          <%= t(".credit") %>
        </h2>

        <div class="text-right">
          <div class="text-sm font-normal"><%= t(".owed") %></div>

          <div class="font-bold">
            <%= number_to_money @credit_accounts.sum(&:balance) %>
          </div>
        </div>
      </div>

      <ul class="divide-y divide-taupe-200" data-collapsible-content="collapsible-credit">
        <% @credit_accounts.each do |account| %>
          <li>
            <%= link_to budget_account_transactions_path(@budget, account),
                        class: "flex items-center justify-between py-3 px-4 bg-white" do %>
              <span class="font-medium"><%= account.name %></span>

              <span class="inline-block py-0.5 px-2 font-semibold rounded-full <%= amount_color(account.balance) %>">
                <%= number_to_money account.balance %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </section>

  <%= render "shared/toolbar", budget: @budget %>
</div>
