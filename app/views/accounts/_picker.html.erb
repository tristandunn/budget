<%# locals: (accounts:, controller:, selected:) %>
<%= render "shared/picker", controller: controller do %>
  <div class="space-y-4">
    <% {
         cash:   accounts.reject(&:credit),
         credit: accounts.select(&:credit)
       }.each do |type, entries| %>
      <% if entries.any? %>
        <%= tag.section(data: { "#{controller}-target" => "group" }) do %>
          <h3 class="px-1 pb-1 text-sm font-semibold text-taupe-800">
            <%= t("accounts.index.#{type}") %>
          </h3>

          <ul class="bg-white rounded-xl divide-y divide-taupe-200" role="listbox">
            <% entries.each do |account| %>
              <%= tag.li(
                    "aria-selected": account == selected,
                    class:           "flex items-center gap-3 px-4 py-3 text-base",
                    data:            {
                      "#{controller}-target": "item",
                      action:                 "click->#{controller}#select",
                      label:                  account.name,
                      value:                  account.id
                    },
                    role:            "option"
                  ) do %>
                <%= account.name %>
              <% end %>
            <% end %>
          </ul>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
