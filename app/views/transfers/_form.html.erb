<%# locals: (accounts:, form:, method:, submit_label:, url:) %>
<div class="self-center py-6 px-8 mx-auto w-full max-w-lg">
  <%= form_with model: form, url: url, method: method, class: "highlight-errors" do |f| %>
    <div>
      <%= f.label :amount, class: "block mb-1 text-sm font-medium text-gray-800 sr-only" %>

      <%= f.number_field :amount,
                         autocomplete: false,
                         autofocus:    true,
                         class:        "w-full text-4xl font-semibold text-center bg-transparent outline-none no-spinner",
                         data:         {
                           action:                  "input->amount#input keydown->amount#keydown paste->amount#paste",
                           "amount-positive-value": "true",
                           controller:              "amount"
                         },
                         inputmode:    "decimal",
                         required:     true,
                         step:         0.01,
                         value:        form.amount || "0.00" %>

      <% if form.errors[:amount].present? %>
        <p class="mt-2 text-xs text-red-700">
          <%= TransferForm.human_attribute_name(:amount) %> <%= form.errors[:amount].first %>.
        </p>
      <% end %>
    </div>

    <div class="mt-6 bg-white rounded-xl divide-y divide-taupe-200">
      <div
        class="flex items-center gap-3 px-4 py-4 cursor-pointer"
        role="button"
        tabindex="0"
        data-action="click->from-account-picker#open keydown->from-account-picker#openOnKey"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 shrink-0 <%= form.from_account.present? ? "text-indigo-600" : "text-taupe-400" %>"
          data-from-account-picker-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M7.78 12.53a.75.75 0 0 1-1.06 0L2.47 8.28a.75.75 0 0 1 0-1.06l4.25-4.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042L4.81 7h7.44a.75.75 0 0 1 0 1.5H4.81l2.97 2.97a.75.75 0 0 1 0 1.06Z"
          />
        </svg>

        <div class="grow">
          <span class="sr-only"><%= TransferForm.human_attribute_name(:from_account) %></span>

          <%= f.hidden_field :from_account_id, value: form.from_account&.id, data: { from_account_picker_target: "hiddenField" } %>

          <span
            data-from-account-picker-target="display"
            class="text-base <%= form.from_account.present? ? "text-gray-800" : "text-gray-400" %>"
          >
            <%= form.from_account&.name || TransferForm.human_attribute_name(:from_account) %>
          </span>

          <% if form.errors[:from_account].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransferForm.human_attribute_name(:from_account) %>
              <%= form.errors[:from_account].first %>.
            </p>
          <% end %>
        </div>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z"
            clip-rule="evenodd"
          />
        </svg>
      </div>

      <div
        class="flex items-center gap-3 px-4 py-4 cursor-pointer"
        role="button"
        tabindex="0"
        data-action="click->to-account-picker#open keydown->to-account-picker#openOnKey"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 shrink-0 <%= form.to_account.present? ? "text-indigo-600" : "text-taupe-400" %>"
          data-to-account-picker-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M8.22 2.97a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042L11.19 8.5H3.75a.75.75 0 0 1 0-1.5h7.44L8.22 4.03a.75.75 0 0 1 0-1.06Z"
          />
        </svg>

        <div class="grow">
          <span class="sr-only"><%= TransferForm.human_attribute_name(:to_account) %></span>

          <%= f.hidden_field :to_account_id, value: form.to_account&.id, data: { to_account_picker_target: "hiddenField" } %>

          <span
            data-to-account-picker-target="display"
            class="text-base <%= form.to_account.present? ? "text-gray-800" : "text-gray-400" %>"
          >
            <%= form.to_account&.name || TransferForm.human_attribute_name(:to_account) %>
          </span>

          <% if form.errors[:to_account].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransferForm.human_attribute_name(:to_account) %>
              <%= form.errors[:to_account].first %>.
            </p>
          <% end %>
        </div>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 0 1 0-1.06Z"
            clip-rule="evenodd"
          />
        </svg>
      </div>

      <label class="group/date flex items-center gap-3 px-4 py-4">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 shrink-0 text-taupe-400 group-has-[input:valid]/date:text-indigo-600"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M4.75 0a.75.75 0 0 1 .75.75V2h5V.75a.75.75 0 0 1 1.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0 1 13.25 16H2.75A1.75 1.75 0 0 1 1 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 0 1 4.75 0ZM2.5 7.5v6.75c0 .138.112.25.25.25h10.5a.25.25 0 0 0 .25-.25V7.5Zm10.75-4H2.75a.25.25 0 0 0-.25.25V6h11V3.75a.25.25 0 0 0-.25-.25Z"
          />
        </svg>

        <div class="grow">
          <span class="sr-only"><%= TransferForm.human_attribute_name(:date) %></span>

          <%= f.date_field :date, class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", max: Date.current, required: true, value: form.date %>

          <% if form.errors[:date].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransferForm.human_attribute_name(:date) %> <%= form.errors[:date].first %>.
            </p>
          <% end %>
        </div>
      </label>
    </div>

    <div class="mt-4 bg-white rounded-xl">
      <label class="group/memo flex items-center gap-3 px-4 py-4">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="
            w-4 h-4 shrink-0 text-taupe-400
            group-has-[input:not(:placeholder-shown)]/memo:text-indigo-600
          "
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M0 3.75C0 2.784.784 2 1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 14H1.75A1.75 1.75 0 0 1 0 12.25Zm1.75-.25a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25v-8.5a.25.25 0 0 0-.25-.25ZM3.5 6.25a.75.75 0 0 1 .75-.75h7a.75.75 0 0 1 0 1.5h-7a.75.75 0 0 1-.75-.75Zm.75 2.25h4a.75.75 0 0 1 0 1.5h-4a.75.75 0 0 1 0-1.5Z"
          />
        </svg>

        <div class="grow">
          <span class="sr-only"><%= TransferForm.human_attribute_name(:memo) %></span>

          <%= f.text_field :memo, class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", placeholder: t(".enter_memo") %>
        </div>
      </label>
    </div>

    <button
      class="
        block p-4 mx-auto mt-6 w-4/5 text-lg font-semibold text-center text-white bg-indigo-600
        rounded-lg hover:bg-indigo-500 focus:outline-none focus:drop-shadow-indigo-200
      "
      type="submit"
    >
      <%= submit_label %>
    </button>
  <% end %>
</div>
