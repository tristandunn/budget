<%# locals: (picker:) %>
<%= render "shared/picker",
           controller:  "category-picker",
           placeholder: t("transactions.form.search_categories") do %>
  <div class="space-y-4">
    <% picker.groups.each do |group| %>
      <%= tag.section(data: { category_picker_target: "group" }) do %>
        <h3 class="px-1 pb-1 text-sm font-semibold text-taupe-800"><%= group.name %></h3>

        <ul class="bg-white rounded-xl divide-y divide-taupe-200" role="listbox">
          <% group.items.each do |item| %>
            <%= tag.li(
                  "aria-selected": item.selected,
                  class:           "flex items-center gap-3 px-4 py-3 text-base cursor-pointer",
                  data:            {
                    action:                 "click->category-picker#select",
                    category_picker_target: "item",
                    label:                  item.name,
                    value:                  item.id
                  },
                  role:            "option"
                ) do %>
              <%= item.name %>

              <span class="ml-auto font-bold <%= picker_amount_class(item.amount_available) %>">
                <%= number_to_money item.amount_available %>
              </span>
            <% end %>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  </div>
<% end %>
