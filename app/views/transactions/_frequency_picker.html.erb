<%# locals: (form:) %>
<%= render "picker", controller: "frequency-picker" do %>
  <ul class="bg-white rounded-xl divide-y divide-taupe-200" role="listbox">
    <%= tag.li(
          "aria-selected": form.frequency.blank?,
          class:           "group flex items-center gap-3 px-4 py-3 text-base cursor-pointer",
          data:            {
            frequency_picker_target: "item",
            action:                  "click->frequency-picker#select",
            label:                   t("transactions.frequency.labels.never"),
            value:                   ""
          },
          role:            "option"
        ) do %>
      <%= render "picker_indicator" %>
      <%= t("transactions.frequency.labels.never") %>
    <% end %>

    <% Transaction.frequencies.each_key do |value| %>
      <%= tag.li(
            "aria-selected": form.frequency == value,
            class:           "group flex items-center gap-3 px-4 py-3 text-base cursor-pointer",
            data:            {
              frequency_picker_target: "item",
              action:                  "click->frequency-picker#select",
              label:                   t("transactions.frequency.labels.#{value}"),
              value:                   value
            },
            role:            "option"
          ) do %>
        <%= render "picker_indicator" %>
        <%= t("transactions.frequency.labels.#{value}") %>
      <% end %>
    <% end %>
  </ul>
<% end %>
