<%= turbo_stream.replace dom_id(@transaction, :status) do %>
  <%= render "transactions/status_indicator", transaction: @transaction %>
<% end %>

<%= turbo_stream.replace "cleared_balance" do %>
  <p id="cleared_balance" class="text-base font-semibold">
    <%= number_to_money @transaction.account.cleared_balance %>
  </p>
<% end %>

<%= turbo_stream.replace "uncleared_balance" do %>
  <p id="uncleared_balance" class="text-base font-semibold">
    <%= number_to_money @transaction.account.uncleared_balance %>
  </p>
<% end %>
