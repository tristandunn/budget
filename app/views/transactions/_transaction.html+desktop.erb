<%# locals: (transaction:, scheduled: false, context: :account) %>
<tr class="border-b border-taupe-300 <%= scheduled ? "bg-taupe-100 text-taupe-700" : "bg-white" %>">
  <% if context == :transactions %>
    <td class="truncate p-2 text-sm"><%= transaction.account.name %></td>
  <% end %>

  <td class="p-2 text-sm whitespace-nowrap">
    <div class="flex items-center gap-2">
      <span class="tabular-nums"><%= l(transaction.date, format: :numeric) %></span>

      <% if scheduled && transaction.frequency.present? %>
        <span class="ml-auto shrink-0" role="img" aria-label="<%= t(".recurring") %>">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 text-taupe-500"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      <% end %>
    </div>
  </td>

  <td class="truncate p-2 text-sm">
    <% if transaction.reconciled? %>
      <%= transaction.payee.name %>
    <% else %>
      <%= link_to transaction.payee.name,
                  edit_budget_transaction_path(transaction.budget, transaction),
                  class: "text-inherit no-underline",
                  data:  { turbo_frame: "transaction_dialog" } %>
    <% end %>
  </td>

  <td class="truncate p-2 text-sm">
    <% if transaction.transfer? %>
      <%= t("transactions.transfer_category") %>
    <% elsif transaction.subcategory %>
      <%= t("transactions.qualified_category",
            category:    transaction.subcategory.parent.name,
            subcategory: transaction.subcategory.name) %>
    <% end %>
  </td>

  <td class="truncate p-2 text-sm <%= scheduled ? "" : "text-taupe-600" %>">
    <%= transaction.memo %>
  </td>

  <td class="p-2 text-sm text-right whitespace-nowrap">
    <% if transaction.amount.negative? %>
      <%= number_to_money(transaction.amount.abs) %>
    <% end %>
  </td>

  <td class="p-2 text-sm text-right whitespace-nowrap">
    <% if transaction.amount.positive? %>
      <%= number_to_money(transaction.amount) %>
    <% end %>
  </td>

  <td class="p-2 text-sm">
    <% unless scheduled %>
      <%= render "transactions/status_indicator", context: context, transaction: transaction %>
    <% end %>
  </td>
</tr>
