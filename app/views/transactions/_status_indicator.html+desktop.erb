<%# locals: (transaction:, context: nil) %>
<div id="<%= dom_id(transaction, :status) %>" class="flex items-center">
  <% if transaction.reconciled? %>
    <span role="img" aria-label="<%= t(".reconciled") %>">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 text-taupe-400"
        viewBox="0 0 16 16"
        fill="currentColor"
      >
        <path
          d="M4 4a4 4 0 0 1 8 0v2h.25c.966 0 1.75.784 1.75 1.75v5.5A1.75 1.75 0 0 1 12.25 15h-8.5A1.75 1.75 0 0 1 2 13.25v-5.5C2 6.784 2.784 6 3.75 6H4Zm8.25 3.5h-8.5a.25.25 0 0 0-.25.25v5.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-5.5a.25.25 0 0 0-.25-.25ZM10.5 6V4a2.5 2.5 0 1 0-5 0v2Z"
        />
      </svg>
    </span>
  <% else %>
    <%= button_to clear_budget_transaction_path(transaction.budget, transaction, context: context),
                  method: transaction.cleared? ? :delete : :patch,
                  title:  transaction.cleared? ? t(".cleared") : t(".pending"),
                  class:  "flex cursor-pointer items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-inset" do %>
      <% if transaction.cleared? %>
        <span
          aria-hidden="true"
          class="
            flex h-4 w-4 items-center justify-center rounded-full bg-lime-600 text-[0.625rem]
            font-bold text-white
          "
        >
          C
        </span>
      <% else %>
        <span aria-hidden="true" class="block h-4 w-4 rounded-full border-2 border-taupe-300"></span>
      <% end %>

      <span class="sr-only"><%= transaction.cleared? ? t(".cleared") : t(".pending") %></span>
    <% end %>
  <% end %>
</div>
