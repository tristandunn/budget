<%# locals: (budget:) %>
<div data-controller="popover" class="relative">
  <button
    type="button"
    data-action="popover#toggle"
    aria-label="<%= t("transactions.index.actions") %>"
    class="
      m-0.5 flex h-6 w-6 items-center justify-center rounded-full border-2 border-taupe-800
      leading-none text-taupe-800
    "
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 16 16"
      class="h-[18px] w-[18px] translate-y-px"
      fill="currentColor"
    >
      <path
        d="M8 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM3.5 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm9 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
      ></path>
    </svg>
  </button>

  <div
    data-popover-target="menu"
    class="
      absolute right-0 top-full z-10 mt-1 overflow-hidden rounded-lg border border-taupe-200
      bg-white whitespace-nowrap shadow-lg hidden
    "
  >
    <%= render "shared/transactions/hide_reconciled", budget: budget %>
  </div>
</div>
