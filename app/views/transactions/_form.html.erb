<%# locals: (accounts:, categories:, form:, method:, submit_label:, url:) %>
<div class="self-center py-6 px-8 mx-auto w-full max-w-lg">
  <%= form_with model: form, url: url, method: method, class: "highlight-errors" do |f| %>
    <div>
      <%= f.label :amount, class: "block mb-1 text-sm font-medium text-gray-800 sr-only" %>
      <%= f.number_field :amount, autocomplete: false, autofocus: true, class: "w-full text-4xl font-semibold text-center bg-transparent outline-none no-spinner", required: true, inputmode: "decimal", step: 0.01, value: form.amount || "0.00", data: { controller: "amount", action: "input->amount#input keydown->amount#keydown paste->amount#paste" } %>

      <% if form.errors[:amount].present? %>
        <p class="mt-2 text-xs text-red-700">
          <%= TransactionForm.human_attribute_name(:amount).humanize %>
          <%= form.errors[:amount].first %>.
        </p>
      <% end %>
    </div>

    <div class="mt-6 bg-white rounded-xl divide-y divide-taupe-200">
      <div
        class="flex items-center gap-3 px-4 py-4"
        data-controller="field-icon"
        data-action="input->field-icon#update click->field-icon#focus"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          data-field-icon-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M5.22 14.78a.75.75 0 0 0 1.06-1.06L4.56 12h8.69a.75.75 0 0 0 0-1.5H4.56l1.72-1.72a.75.75 0 0 0-1.06-1.06l-3 3a.75.75 0 0 0 0 1.06l3 3Zm5.56-6.5a.75.75 0 1 1-1.06-1.06l1.72-1.72H2.75a.75.75 0 0 1 0-1.5h8.69L9.72 2.28a.75.75 0 0 1 1.06-1.06l3 3a.75.75 0 0 1 0 1.06l-3 3Z"
          />
        </svg>

        <div class="grow">
          <%= f.label :payee, class: "block mb-1 text-sm font-medium text-gray-800 sr-only" %>
          <%= f.text_field :payee, class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", placeholder: t(".enter_payee"), required: true %>

          <% if form.errors[:payee].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransactionForm.human_attribute_name(:payee).humanize %>
              <%= form.errors[:payee].first %>.
            </p>
          <% end %>
        </div>
      </div>

      <%= f.label :subcategory_id, class: "flex items-center gap-3 px-4 py-4", data: { controller: "field-icon", action: "change->field-icon#update click->field-icon#focus" } do %>
        <span class="sr-only"><%= TransactionForm.human_attribute_name(:subcategory_id) %></span>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          data-field-icon-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M0 2.75C0 1.784.784 1 1.75 1H5c.55 0 1.07.26 1.4.7l.9 1.2a.25.25 0 0 0 .2.1h6.75c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 15H1.75A1.75 1.75 0 0 1 0 13.25Zm1.75-.25a.25.25 0 0 0-.25.25v10.5c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25v-8.5a.25.25 0 0 0-.25-.25H7.5c-.55 0-1.07-.26-1.4-.7l-.9-1.2a.25.25 0 0 0-.2-.1Z"
          />
        </svg>

        <div class="grow">
          <%= f.grouped_collection_select :subcategory_id, categories, :subcategories_by_position, :name, :id, :name, { prompt: t(".select_subcategory"), selected: form.subcategory&.id }, { class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", required: true } %>

          <% if form.errors[:subcategory].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransactionForm.human_attribute_name(:subcategory_id).humanize %>
              <%= form.errors[:subcategory].first %>.
            </p>
          <% end %>
        </div>
      <% end %>

      <%= f.label :account_id, class: "flex items-center gap-3 px-4 py-4", data: { controller: "field-icon", action: "change->field-icon#update click->field-icon#focus" } do %>
        <span class="sr-only"><%= TransactionForm.human_attribute_name(:account_id) %></span>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          data-field-icon-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M1.75 16A1.75 1.75 0 0 1 0 14.25V1.75C0 .784.784 0 1.75 0h8.5C11.216 0 12 .784 12 1.75v12.5c0 .085-.006.168-.018.25h2.268a.25.25 0 0 0 .25-.25V8.285a.25.25 0 0 0-.111-.208l-1.055-.703a.749.749 0 1 1 .832-1.248l1.055.703c.487.325.779.871.779 1.456v5.965A1.75 1.75 0 0 1 14.25 16h-3.5a.766.766 0 0 1-.197-.026c-.099.017-.2.026-.303.026h-3a.75.75 0 0 1-.75-.75V14h-1v1.25a.75.75 0 0 1-.75.75Zm-.25-1.75c0 .138.112.25.25.25H4v-1.25a.75.75 0 0 1 .75-.75h2.5a.75.75 0 0 1 .75.75v1.25h2.25a.25.25 0 0 0 .25-.25V1.75a.25.25 0 0 0-.25-.25h-8.5a.25.25 0 0 0-.25.25ZM3.75 6h.5a.75.75 0 0 1 0 1.5h-.5a.75.75 0 0 1 0-1.5ZM3 3.75A.75.75 0 0 1 3.75 3h.5a.75.75 0 0 1 0 1.5h-.5A.75.75 0 0 1 3 3.75Zm4 3A.75.75 0 0 1 7.75 6h.5a.75.75 0 0 1 0 1.5h-.5A.75.75 0 0 1 7 6.75ZM7.75 3h.5a.75.75 0 0 1 0 1.5h-.5a.75.75 0 0 1 0-1.5ZM3 9.75A.75.75 0 0 1 3.75 9h.5a.75.75 0 0 1 0 1.5h-.5A.75.75 0 0 1 3 9.75ZM7.75 9h.5a.75.75 0 0 1 0 1.5h-.5a.75.75 0 0 1 0-1.5Z"
          />
        </svg>

        <div class="grow">
          <%= f.collection_select :account_id, accounts, :id, :name, { prompt: t(".select_account"), selected: form.account&.id }, { class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", required: true } %>

          <% if form.errors[:account].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransactionForm.human_attribute_name(:account_id).humanize %>
              <%= form.errors[:account].first %>.
            </p>
          <% end %>
        </div>
      <% end %>

      <div
        class="flex items-center gap-3 px-4 py-4"
        data-controller="field-icon"
        data-action="input->field-icon#update click->field-icon#focus"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          data-field-icon-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M4.75 0a.75.75 0 0 1 .75.75V2h5V.75a.75.75 0 0 1 1.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0 1 13.25 16H2.75A1.75 1.75 0 0 1 1 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 0 1 4.75 0ZM2.5 7.5v6.75c0 .138.112.25.25.25h10.5a.25.25 0 0 0 .25-.25V7.5Zm10.75-4H2.75a.25.25 0 0 0-.25.25V6h11V3.75a.25.25 0 0 0-.25-.25Z"
          />
        </svg>

        <div class="grow">
          <%= f.label :date, class: "block mb-1 text-sm font-medium text-gray-800 sr-only" %>
          <%= f.date_field :date, class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", required: true, value: form.date %>

          <% if form.errors[:date].present? %>
            <p class="mt-2 text-xs text-red-700">
              <%= TransactionForm.human_attribute_name(:date).humanize %>
              <%= form.errors[:date].first %>.
            </p>
          <% end %>
        </div>
      </div>

      <%= f.label :frequency, class: "flex items-center gap-3 px-4 py-4", data: { controller: "field-icon", action: "change->field-icon#update click->field-icon#focus" } do %>
        <span class="sr-only"><%= TransactionForm.human_attribute_name(:frequency) %></span>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          data-field-icon-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M5.029 2.217a6.5 6.5 0 0 1 9.437 5.11.75.75 0 1 0 1.492-.154 8 8 0 0 0-11.61-6.28l-.546-.607a.75.75 0 0 0-1.302.51v3.428a.75.75 0 0 0 .8.75l3.428-.2a.75.75 0 0 0 .502-1.26l-.755-.839Zm5.942 11.566a6.5 6.5 0 0 1-9.437-5.11.75.75 0 1 0-1.492.154 8 8 0 0 0 11.61 6.28l.546.607a.75.75 0 0 0 1.302-.51v-3.428a.75.75 0 0 0-.8-.75l-3.428.2a.75.75 0 0 0-.502 1.26l.755.839Z"
          />
        </svg>

        <div class="grow">
          <%= f.select :frequency, options_for_select([%w(Monthly monthly)], form.frequency), { prompt: t(".select_frequency") }, { class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0" } %>
        </div>
      <% end %>
    </div>

    <div class="mt-4 bg-white rounded-xl">
      <div
        class="flex items-center gap-3 px-4 py-4"
        data-controller="field-icon"
        data-action="input->field-icon#update click->field-icon#focus"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          data-field-icon-target="icon"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            d="M0 3.75C0 2.784.784 2 1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 14H1.75A1.75 1.75 0 0 1 0 12.25Zm1.75-.25a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25v-8.5a.25.25 0 0 0-.25-.25ZM3.5 6.25a.75.75 0 0 1 .75-.75h7a.75.75 0 0 1 0 1.5h-7a.75.75 0 0 1-.75-.75Zm.75 2.25h4a.75.75 0 0 1 0 1.5h-4a.75.75 0 0 1 0-1.5Z"
          />
        </svg>

        <div class="grow">
          <%= f.label :memo, class: "block mb-1 text-sm font-medium text-gray-800 sr-only" %>
          <%= f.text_field :memo, class: "w-full bg-transparent border-none outline-none text-base placeholder:text-gray-400 focus:ring-0", placeholder: t(".enter_memo") %>
        </div>
      </div>
    </div>

    <button
      class="
        block p-4 mx-auto mt-6 w-4/5 text-lg font-semibold text-center text-white bg-indigo-600
        rounded-lg hover:bg-indigo-500 focus:outline-none focus:drop-shadow-indigo-200
      "
      type="submit"
    >
      <%= submit_label %>
    </button>
  <% end %>
</div>
