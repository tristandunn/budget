<%= turbo_frame_tag "transaction_dialog", class: "flex flex-col h-full" do %>
  <div
    data-controller="payee-picker category-picker account-picker frequency-picker"
    class="relative flex flex-col h-full overflow-x-clip"
  >
    <div>
      <header class="relative p-4">
        <h2 class="text-lg font-semibold text-center"><%= t(".title") %></h2>

        <button
          type="button"
          class="absolute top-4 left-4 text-sm cursor-pointer"
          data-action="dialog#close"
        >
          <%= t(".cancel") %>
        </button>
      </header>

      <%= render "form",
                 form:         @form,
                 method:       :post,
                 submit_label: t(".submit"),
                 url:          budget_transactions_path(@form.budget) %>
    </div>

    <%= render "payee_picker", form: @form, payees: @payees %>
    <%= render "category_picker", picker: @category_picker %>

    <%= render "accounts/picker",
               accounts:   @accounts,
               controller: "account-picker",
               selected:   @form.account %>

    <%= render "frequency_picker", form: @form %>
  </div>
<% end %>
