<%= turbo_frame_tag "payees_dialog", class: "flex flex-col h-full" do %>
  <header class="relative p-4">
    <h2 id="payees_dialog_title" class="text-lg font-semibold text-center">
      <%= t(".title") %>
    </h2>

    <button
      type="button"
      data-action="dialog#close"
      class="absolute top-4 right-4 text-sm text-taupe-600 cursor-pointer"
    >
      <%= t(".done") %>
    </button>
  </header>

  <div data-controller="payee-manager" class="flex flex-col flex-1 min-h-0">
    <div class="px-4 pb-4">
      <div class="flex items-center gap-3 px-4 py-3 bg-white rounded-xl">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-taupe-400 shrink-0"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
            clip-rule="evenodd"
          />
        </svg>

        <%= tag.input(
              "aria-label":   t(".search"),
              autocapitalize: "words",
              autocomplete:   "off",
              autocorrect:    "off",
              class:          "grow bg-transparent border-none outline-none text-base placeholder:text-taupe-400 focus:ring-0 p-0",
              data:           {
                action:               "input->payee-manager#filter search->payee-manager#filter",
                payee_manager_target: "search"
              },
              enterkeyhint:   "search",
              placeholder:    t(".search"),
              type:           "search"
            ) %>
      </div>
    </div>

    <div class="flex-1 px-4 pb-4 overflow-y-auto">
      <%= turbo_frame_tag "payees_list" do %>
        <%= render "list", budget: @budget, payees: @payees %>
      <% end %>

      <p data-payee-manager-target="empty" class="hidden mt-4 text-center text-sm text-taupe-600">
        <%= t(".no_matches") %>
      </p>
    </div>
  </div>
<% end %>
