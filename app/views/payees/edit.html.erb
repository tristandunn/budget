<%= turbo_frame_tag "payee_rename_dialog", class: "flex flex-col h-full" do %>
  <header class="relative p-4">
    <h2 id="payee_rename_dialog_title" class="text-lg font-semibold text-center">
      <%= t(".title") %>
    </h2>

    <button
      type="button"
      data-action="dialog#close"
      class="absolute top-4 left-4 text-sm cursor-pointer"
    >
      <%= t(".cancel") %>
    </button>

    <button
      type="submit"
      form="payee_form"
      class="absolute top-4 right-4 text-sm font-semibold text-indigo-600 cursor-pointer"
    >
      <%= t(".submit") %>
    </button>
  </header>

  <div class="self-center py-6 px-8 mx-auto w-full max-w-lg">
    <%= form_with model:  @form,
                  url:    budget_payee_path(@budget, @payee),
                  method: :patch,
                  id:     "payee_form",
                  class:  "highlight-errors" do |f| %>
      <div class="bg-white rounded-xl">
        <div
          class="
            flex items-center gap-3 px-4 py-4 rounded-xl focus-within:outline-none
            focus-within:ring-2 focus-within:ring-indigo-500 focus-within:ring-inset
          "
        >
          <div class="grow">
            <%= f.label :name, class: "sr-only" %>

            <%= f.text_field :name,
                             autocapitalize: "words",
                             autocorrect:    "off",
                             autofocus:      true,
                             class:          "w-full bg-transparent border-none outline-none text-base placeholder:text-taupe-400 focus:ring-0",
                             placeholder:    t(".enter_name"),
                             required:       true %>

            <% if @form.errors[:name].present? %>
              <p class="mt-2 text-xs text-red-700">
                <%= PayeeForm.human_attribute_name(:name).humanize %>
                <%= @form.errors[:name].first %>.
              </p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
