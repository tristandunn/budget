<%# locals: (progress:, label:, css_class: "w-4 h-4 self-center") %>
<svg class="<%= css_class %>" viewBox="0 0 20 20" role="img">
  <title><%= label %></title>

  <circle
    cx="10"
    cy="10"
    r="8"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  />

  <% if progress.funded? %>
    <path
      d="M 6.5 10 L 9 12.5 L 13.5 7.5"
      fill="none"
      stroke="currentColor"
      stroke-width="2.25"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  <% else %>
    <circle
      cx="10"
      cy="10"
      r="3"
      fill="none"
      stroke="currentColor"
      stroke-width="6"
      pathLength="100"
      stroke-dasharray="<%= progress.funded_percentage %> 100"
      transform="rotate(-90 10 10)"
    />
  <% end %>
</svg>
